<Page
    x:Class="UniMatrix.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:UniMatrix"
    Background="{StaticResource AppBackgroundBrush}">

    <Grid>

        <!-- ============================ SPLASH ============================ -->
        <!-- Shown while restoring a saved session so the login form doesn't flash.
             Visible by default so it appears instantly before code-behind runs. -->
        <Grid x:Name="SplashPanel" Background="{StaticResource AppBackgroundBrush}"
              Visibility="Visible">
            <Grid.Resources>
                <Storyboard x:Name="SplashFadeIn">
                    <DoubleAnimation Storyboard.TargetName="SplashContent"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.4" />
                    <DoubleAnimation Storyboard.TargetName="SplashContentTransform"
                                     Storyboard.TargetProperty="Y"
                                     From="16" To="0" Duration="0:0:0.4">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
                <Storyboard x:Name="SplashPulse" RepeatBehavior="Forever" AutoReverse="True">
                    <DoubleAnimation Storyboard.TargetName="SplashStatus"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0.4" To="1" Duration="0:0:0.9">
                        <DoubleAnimation.EasingFunction>
                            <SineEase EasingMode="EaseInOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </Grid.Resources>
            <StackPanel x:Name="SplashContent" HorizontalAlignment="Center"
                        VerticalAlignment="Center" MaxWidth="320" Padding="24" Opacity="0">
                <StackPanel.RenderTransform>
                    <TranslateTransform x:Name="SplashContentTransform" />
                </StackPanel.RenderTransform>
                <Image Source="ms-appx:///Assets/unimatrix_banner.png" Stretch="Uniform"
                       MaxWidth="240" HorizontalAlignment="Center" />
                <ProgressRing Width="36" Height="36" Margin="0,28,0,0" IsActive="True"
                              Foreground="{StaticResource AppAccentBrush}" />
                <TextBlock x:Name="SplashStatus" Text="Logging in…"
                           Foreground="{StaticResource AppSubtleTextBrush}"
                           FontSize="14" HorizontalAlignment="Center" Margin="0,16,0,0" />
            </StackPanel>
        </Grid>

        <!-- ============================ LOGIN ============================ -->
        <Grid x:Name="LoginPanel" Background="{StaticResource AppBackgroundBrush}"
              Visibility="Collapsed">
            <ScrollViewer x:Name="LoginScroll" VerticalScrollBarVisibility="Auto">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top"
                            MaxWidth="420" Padding="24,24">
                    <Image Source="ms-appx:///Assets/unimatrix_banner.png" Stretch="Uniform"
                           MaxWidth="280" HorizontalAlignment="Center" />
                    <TextBlock Text="Matrix chat for Windows Mobile" Foreground="{StaticResource AppSubtleTextBrush}"
                               FontSize="14" HorizontalAlignment="Center" Margin="0,8,0,32" />

                    <TextBlock Text="HOMESERVER" Foreground="{StaticResource AppFaintTextBrush}"
                               FontSize="11" FontWeight="SemiBold" Margin="2,0,0,4" />
                    <TextBox x:Name="LoginServerBox" Text="matrix.org" Margin="0,0,0,16"
                             Background="{StaticResource AppCardBrush}" BorderThickness="0"
                             KeyDown="LoginField_KeyDown" />

                    <TextBlock Text="USERNAME" Foreground="{StaticResource AppFaintTextBrush}"
                               FontSize="11" FontWeight="SemiBold" Margin="2,0,0,4" />
                    <TextBox x:Name="LoginUserBox" PlaceholderText="user" Margin="0,0,0,16"
                             Background="{StaticResource AppCardBrush}" BorderThickness="0"
                             KeyDown="LoginField_KeyDown" />

                    <TextBlock Text="PASSWORD" Foreground="{StaticResource AppFaintTextBrush}"
                               FontSize="11" FontWeight="SemiBold" Margin="2,0,0,4" />
                    <PasswordBox x:Name="LoginPassBox" Margin="0,0,0,24"
                                 Background="{StaticResource AppCardBrush}" BorderThickness="0"
                                 KeyDown="LoginField_KeyDown" />

                    <Button x:Name="LoginButton" Content="Sign in" Click="LoginButton_Click"
                            HorizontalAlignment="Stretch" Padding="0,12"
                            Background="{StaticResource AppAccentBrush}" Foreground="White"
                            FontSize="16" FontWeight="SemiBold" />

                    <TextBlock x:Name="LoginError" Foreground="#FF6B6B" FontSize="13"
                               TextWrapping="Wrap" Margin="0,16,0,0" Visibility="Collapsed" />
                    <ProgressRing x:Name="LoginProgress" Width="32" Height="32" Margin="0,16,0,0"
                                  Foreground="{StaticResource AppAccentBrush}" IsActive="False" />
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ============================ SETUP ============================ -->
        <!-- Shown once after a fresh login to capture initial preferences. -->
        <Grid x:Name="SetupPanel" Background="{StaticResource AppBackgroundBrush}"
              Visibility="Collapsed">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            MaxWidth="420" Padding="24,48">
                    <Image Source="ms-appx:///Assets/unimatrix_banner.png" Stretch="Uniform"
                           MaxWidth="240" HorizontalAlignment="Center" />
                    <TextBlock Text="Let's set things up" Foreground="White" FontSize="20"
                               FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,16,0,4" />
                    <TextBlock Text="You can change these later in Settings."
                               Foreground="{StaticResource AppSubtleTextBrush}" FontSize="13"
                               HorizontalAlignment="Center" Margin="0,0,0,32" TextAlignment="Center" />

                    <TextBlock Text="MESSAGE HISTORY" Foreground="{StaticResource AppFaintTextBrush}"
                               FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock Text="How many days of history to load per room" Foreground="White"
                               FontSize="14" TextWrapping="Wrap" />
                    <Slider x:Name="SetupHistorySlider" Minimum="7" Maximum="365" StepFrequency="1"
                            TickFrequency="30" ValueChanged="SetupHistorySlider_ValueChanged"
                            Foreground="{StaticResource AppAccentBrush}" Margin="0,8,0,0" />
                    <TextBlock x:Name="SetupHistoryValue" Text="" Foreground="{StaticResource AppSubtleTextBrush}"
                               FontSize="13" />

                    <Button x:Name="SetupContinueButton" Content="Continue" Click="SetupContinueButton_Click"
                            HorizontalAlignment="Stretch" Padding="0,12" Margin="0,32,0,0"
                            Background="{StaticResource AppAccentBrush}" Foreground="White"
                            FontSize="16" FontWeight="SemiBold" />
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ========================= ROOM LIST ========================= -->
        <Grid x:Name="RoomListView" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Background="{StaticResource AppPanelBrush}" Padding="14,4" Height="64">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <!-- Tap the connection dot (orange/green/red) to open the debug log. -->
                <Button Grid.Column="0" Click="DebugToggle_Click" Background="Transparent"
                        BorderThickness="0" Padding="0" Margin="0,0,10,0"
                        VerticalAlignment="Center" MinWidth="0" MinHeight="0">
                    <Ellipse x:Name="SyncLed" Width="10" Height="10" Fill="#777777" />
                </Button>
                <Image Grid.Column="1" Source="ms-appx:///Assets/unimatrix_banner.png"
                       Stretch="Uniform" HorizontalAlignment="Left" VerticalAlignment="Center"
                       Height="52" />
                <Button Grid.Column="2" Click="NewRoomButton_Click" Background="Transparent"
                        BorderThickness="0" Padding="10" VerticalAlignment="Center">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE710;" FontSize="18" Foreground="White" />
                </Button>
                <Button Grid.Column="3" Click="SettingsButton_Click" Background="Transparent"
                        BorderThickness="0" Padding="10" VerticalAlignment="Center">
                    <Grid Width="28" Height="28">
                        <FontIcon x:Name="SettingsNavIcon" FontFamily="Segoe MDL2 Assets" Glyph="&#xE713;"
                                  FontSize="18" Foreground="White" />
                        <Ellipse x:Name="HeaderAvatarImage" Width="28" Height="28" Visibility="Collapsed" />
                    </Grid>
                </Button>
            </Grid>

            <!-- Rooms -->
            <ListView Grid.Row="1" x:Name="RoomsList" SelectionMode="None"
                      IsItemClickEnabled="True" ItemClick="RoomsList_ItemClick"
                      ItemsSource="{x:Bind Rooms}"
                      ScrollViewer.HorizontalScrollMode="Disabled">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="MinHeight" Value="0" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="14,10" Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <!-- Avatar -->
                            <Grid Grid.Column="0" Width="48" Height="48" Margin="0,0,12,0">
                                <Ellipse Fill="{Binding AvatarBrush}" Visibility="{Binding InitialVisibility}" />
                                <TextBlock Text="{Binding AvatarInitial}" Foreground="White"
                                           FontSize="20" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="{Binding InitialVisibility}" />
                                <Ellipse Visibility="{Binding AvatarVisibility}">
                                    <Ellipse.Fill>
                                        <ImageBrush ImageSource="{Binding AvatarUrl}" Stretch="UniformToFill" />
                                    </Ellipse.Fill>
                                </Ellipse>
                            </Grid>

                            <!-- Name + preview -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding DisplayName}" Foreground="White"
                                               FontSize="16" FontWeight="SemiBold"
                                               TextTrimming="CharacterEllipsis" MaxLines="1" />
                                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE72E;" FontSize="12"
                                              Foreground="{StaticResource AppAccentBrush}"
                                              VerticalAlignment="Center" Margin="6,1,0,0"
                                              Visibility="{Binding EncryptedVisibility}" />
                                </StackPanel>
                                <TextBlock Text="{Binding LastPreview}" Foreground="{StaticResource AppSubtleTextBrush}"
                                           FontSize="13" TextTrimming="CharacterEllipsis" MaxLines="1"
                                           Margin="0,2,0,0" Visibility="{Binding PreviewVisibility}" />
                                <TextBlock Text="Invitation &#8212; tap to accept"
                                           Foreground="{StaticResource AppAccentBrush}"
                                           FontSize="13" FontWeight="SemiBold" MaxLines="1"
                                           TextTrimming="CharacterEllipsis" Margin="0,2,0,0"
                                           Visibility="{Binding InviteVisibility}" />
                            </StackPanel>

                            <!-- Unread badge -->
                            <Border Grid.Column="2" Background="{StaticResource AppAccentBrush}"
                                    CornerRadius="11" MinWidth="22" Height="22" Padding="7,0"
                                    VerticalAlignment="Center" Visibility="{Binding UnreadVisibility}">
                                <TextBlock Text="{Binding UnreadText}" Foreground="White" FontSize="12"
                                           FontWeight="SemiBold" HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Empty state -->
            <StackPanel Grid.Row="1" x:Name="RoomsEmpty" VerticalAlignment="Center"
                        HorizontalAlignment="Center" Visibility="Collapsed">
                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8BD;" FontSize="48"
                          Foreground="{StaticResource AppFaintTextBrush}" HorizontalAlignment="Center" />
                <TextBlock Text="No rooms yet" Foreground="{StaticResource AppSubtleTextBrush}"
                           FontSize="16" HorizontalAlignment="Center" Margin="0,12,0,0" />
                <TextBlock x:Name="SyncErrorText" Foreground="#FF6B6B" TextWrapping="Wrap"
                           FontSize="12" HorizontalAlignment="Center" TextAlignment="Center"
                           Margin="24,12,24,0" Visibility="Collapsed" />
            </StackPanel>
        </Grid>

        <!-- =========================== CHAT =========================== -->
        <Grid x:Name="ChatView" Visibility="Collapsed">
            <Grid.Resources>
                <!-- Short entrance used when jumping straight into a freshly created direct chat
                     (see PlayChatEnterAnimation). Normal room opens don't trigger it. -->
                <Storyboard x:Name="ChatEnter">
                    <DoubleAnimation Storyboard.TargetName="ChatView"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.25" />
                    <DoubleAnimation Storyboard.TargetName="ChatViewTransform"
                                     Storyboard.TargetProperty="Y"
                                     From="14" To="0" Duration="0:0:0.25">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut" />
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </Grid.Resources>
            <Grid.RenderTransform>
                <TranslateTransform x:Name="ChatViewTransform" />
            </Grid.RenderTransform>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Chat header -->
            <Grid Grid.Row="0" Background="{StaticResource AppPanelBrush}" Padding="6,8" Height="64">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Click="ChatBackButton_Click" Background="Transparent"
                        BorderThickness="0" Padding="12,8" VerticalAlignment="Center">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE72B;" FontSize="18" Foreground="White" />
                </Button>
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="ChatRoomName" Text="" Foreground="White" FontSize="17"
                                   FontWeight="SemiBold" TextTrimming="CharacterEllipsis" MaxLines="1" />
                        <FontIcon x:Name="ChatEncryptedIcon" FontFamily="Segoe MDL2 Assets" Glyph="&#xE72E;"
                                  FontSize="13" Foreground="{StaticResource AppAccentBrush}"
                                  VerticalAlignment="Center" Margin="6,1,0,0" Visibility="Collapsed" />
                    </StackPanel>
                    <TextBlock x:Name="ChatRoomMembers" Text="" Foreground="{StaticResource AppSubtleTextBrush}"
                               FontSize="12" TextTrimming="CharacterEllipsis" MaxLines="1" />
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="CallButton" Click="CallButton_Click" Background="Transparent"
                            BorderThickness="0" Padding="12,8" VerticalAlignment="Center"
                            ToolTipService.ToolTip="Audio call">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE717;" FontSize="18" Foreground="White" />
                    </Button>
                    <Button x:Name="VideoCallButton" Click="VideoCallButton_Click" Background="Transparent"
                            BorderThickness="0" Padding="12,8" VerticalAlignment="Center"
                            ToolTipService.ToolTip="Video call">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE714;" FontSize="18" Foreground="White" />
                    </Button>
                    <Button Click="RoomInfoButton_Click" Background="Transparent"
                            BorderThickness="0" Padding="12,8" VerticalAlignment="Center">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE946;" FontSize="18" Foreground="White" />
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Messages -->
            <ListView Grid.Row="1" x:Name="MessagesList" SelectionMode="None"
                      ItemsSource="{x:Bind Messages}" Padding="8,8"
                      Loaded="MessagesList_Loaded"
                      ScrollViewer.HorizontalScrollMode="Disabled">
                <!-- ItemsStackPanel with KeepLastItemInView is the platform's chat-list mode: the
                     framework automatically keeps the newest item pinned to the bottom as items are
                     added or resized (e.g. an image bubble growing after its picture decodes), so we
                     don't have to chase a moving ScrollableHeight ourselves. Virtualization stays on,
                     which is fine because the in-memory list is capped at one page (~50). -->
                <ListView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsStackPanel ItemsUpdatingScrollMode="KeepLastItemInView" />
                    </ItemsPanelTemplate>
                </ListView.ItemsPanel>
                <!-- Start with NO item transitions: the default ListView entrance cascade animates
                     every item in when the page is bulk-loaded on open, which looks like the list
                     "growing" from a few items to the full page (it plays even for a 1-message room).
                     SetMessageTransitions(true) re-enables a fade AFTER open settles so only genuinely
                     new (live) messages animate; OpenRoom resets it to empty before each bulk render. -->
                <ListView.ItemContainerTransitions>
                    <TransitionCollection />
                </ListView.ItemContainerTransitions>
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0,2" />
                        <Setter Property="MinHeight" Value="0" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel HorizontalAlignment="Stretch">
                            <!-- Telegram-style date separator pill, shown when the day changes. -->
                            <Border HorizontalAlignment="Center" Margin="0,8,0,8"
                                    Background="{StaticResource AppPanelBrush}" CornerRadius="10"
                                    Padding="12,4" Visibility="{Binding DateSeparatorVisibility}">
                                <TextBlock Text="{Binding DateSeparatorText}"
                                           Foreground="{StaticResource AppSubtleTextBrush}"
                                           FontSize="12" FontWeight="SemiBold" />
                            </Border>
                            <Border Background="{Binding BubbleBrush}" CornerRadius="10"
                                    Padding="10,7" MaxWidth="300"
                                    Visibility="{Binding BubbleVisibility}"
                                    HorizontalAlignment="{Binding Alignment}">
                                <Border.ContextFlyout>
                                    <MenuFlyout>
                                        <MenuFlyoutItem Text="Copy" Click="MessageCopy_Click" />
                                    </MenuFlyout>
                                </Border.ContextFlyout>
                                <StackPanel>
                                    <TextBlock Text="{Binding SenderShort}" Foreground="{StaticResource AppAccentBrush}"
                                               FontSize="12" FontWeight="SemiBold"
                                               Visibility="{Binding SenderVisibility}" Margin="0,0,0,2" />
                                    <TextBlock Text="{Binding Body}" Foreground="White" FontSize="15"
                                               TextWrapping="Wrap" Visibility="{Binding TextVisibility}" />
                                    <Image Source="{Binding MediaUrl}" Stretch="Uniform" MaxHeight="220"
                                           Visibility="{Binding ImageVisibility}" Margin="0,2,0,0"
                                           Tapped="MessageImage_Tapped" />
                                    <TextBlock Text="{Binding TimeText}" Foreground="#CCFFFFFF"
                                               FontSize="10" HorizontalAlignment="Right" Margin="0,3,0,0" />
                                </StackPanel>
                            </Border>

                            <!-- Voice/video call marker (m.call.*), centered system-style pill.
                                 Icon colour conveys the outcome: red=missed, blue=incoming, green=outgoing. -->
                            <Border HorizontalAlignment="Center" Margin="0,4"
                                    Background="{StaticResource AppPanelBrush}" CornerRadius="14"
                                    Padding="14,6" Visibility="{Binding CallVisibility}">
                                <StackPanel Orientation="Horizontal">
                                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="{Binding CallIcon}"
                                              Foreground="{Binding CallIconBrush}" FontSize="14"
                                              VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <TextBlock Text="{Binding CallLabel}" Foreground="{StaticResource AppSubtleTextBrush}"
                                               FontSize="13" VerticalAlignment="Center" />
                                    <TextBlock Text="{Binding CallDurationText}" Foreground="{StaticResource AppSubtleTextBrush}"
                                               FontSize="13" Margin="6,0,0,0" VerticalAlignment="Center"
                                               Visibility="{Binding CallDurationVisibility}" />
                                    <TextBlock Text="{Binding TimeText}" Foreground="{StaticResource AppFaintTextBrush}"
                                               FontSize="11" Margin="8,0,0,0" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Composer -->
            <Grid Grid.Row="2" Background="{StaticResource AppPanelBrush}" Padding="8,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" x:Name="AttachButton" Click="AttachButton_Click"
                        Background="Transparent" BorderThickness="0"
                        Margin="0,0,4,0" Padding="10,10" VerticalAlignment="Stretch">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE723;" FontSize="18" Foreground="#CCFFFFFF" />
                </Button>
                <TextBox Grid.Column="1" x:Name="MessageBox" PlaceholderText="Message"
                         Background="{StaticResource AppCardBrush}" BorderThickness="0"
                         TextWrapping="Wrap" AcceptsReturn="False" VerticalAlignment="Center"
                         KeyDown="MessageBox_KeyDown" />
                <Button Grid.Column="2" x:Name="SendButton" Click="SendButton_Click"
                        Background="{StaticResource AppAccentBrush}" BorderThickness="0"
                        Margin="8,0,0,0" Padding="14,10" VerticalAlignment="Stretch">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE724;" FontSize="18" Foreground="White" />
                </Button>
            </Grid>
        </Grid>

        <!-- ========================= ROOM INFO ========================= -->
        <Grid x:Name="RoomInfoPanel" Background="{StaticResource AppBackgroundBrush}" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Background="{StaticResource AppPanelBrush}" Padding="6,8" Height="64">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Click="RoomInfoCloseButton_Click" Background="Transparent"
                        BorderThickness="0" Padding="12,8" VerticalAlignment="Center">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE72B;" FontSize="18" Foreground="White" />
                </Button>
                <TextBlock Grid.Column="1" Text="Room info" Foreground="White" FontSize="18"                           FontWeight="SemiBold" VerticalAlignment="Center" />
            </Grid>
            <ScrollViewer Grid.Row="1">
                <StackPanel Padding="24" HorizontalAlignment="Center" MaxWidth="420">
                    <Grid Width="120" Height="120" Margin="0,16,0,16">
                        <Ellipse x:Name="InfoAvatarFallback" Fill="{StaticResource AppCardBrush}" />
                        <TextBlock x:Name="InfoAvatarInitial" Foreground="White" FontSize="48"
                                   FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <Ellipse x:Name="InfoAvatarImage" Visibility="Collapsed" />
                    </Grid>
                    <TextBlock x:Name="InfoRoomName" Text="" Foreground="White" FontSize="22"
                               FontWeight="SemiBold" TextWrapping="Wrap" HorizontalAlignment="Center"
                               TextAlignment="Center" />
                    <TextBlock x:Name="InfoMembers" Text="" Foreground="{StaticResource AppAccentBrush}"
                               FontSize="14" HorizontalAlignment="Center" Margin="0,4,0,0" />
                    <TextBlock x:Name="InfoTopic" Text="" Foreground="{StaticResource AppSubtleTextBrush}"
                               FontSize="14" TextWrapping="Wrap" Margin="0,16,0,0" HorizontalAlignment="Center"
                               TextAlignment="Center" />
                    <TextBlock x:Name="InfoRoomId" Text="" Foreground="{StaticResource AppFaintTextBrush}"
                               FontSize="12" TextWrapping="Wrap" Margin="0,16,0,0" HorizontalAlignment="Center"
                               TextAlignment="Center" />

                    <!-- Encryption status / enable -->
                    <Border x:Name="InfoEncryptedRow" Background="{StaticResource AppCardBrush}"
                            CornerRadius="8" Padding="12" Margin="0,24,0,0" Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE72E;" FontSize="16"
                                      Foreground="{StaticResource AppAccentBrush}" VerticalAlignment="Center" />
                            <TextBlock Text="Messages are end-to-end encrypted" Margin="8,0,0,0"
                                       VerticalAlignment="Center" Foreground="White" FontSize="14"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                    <Button x:Name="EnableEncryptionButton" Click="EnableEncryptionButton_Click"
                            HorizontalAlignment="Stretch" Margin="0,24,0,0" Padding="0,12"
                            Background="{StaticResource AppCardBrush}" Foreground="White" BorderThickness="0"
                            Visibility="Collapsed">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE72E;" FontSize="16"
                                      Foreground="{StaticResource AppAccentBrush}" VerticalAlignment="Center" />
                            <TextBlock Text="Enable encryption" Margin="8,0,0,0" VerticalAlignment="Center"
                                       FontSize="15" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="LeaveRoomButton" Click="LeaveRoomButton_Click"
                            HorizontalAlignment="Stretch" Margin="0,32,0,0" Padding="0,12"
                            Background="#3A1A1A" Foreground="#FF6B6B" BorderThickness="0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE7E8;" FontSize="16"
                                      Foreground="#FF6B6B" VerticalAlignment="Center" />
                            <TextBlock Text="Leave room" Margin="8,0,0,0" VerticalAlignment="Center"
                                       FontSize="15" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ========================= INVITE ========================= -->
        <Grid x:Name="InvitePanel" Background="{StaticResource AppBackgroundBrush}" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Background="{StaticResource AppPanelBrush}" Padding="6,8" Height="64">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Click="InviteCloseButton_Click" Background="Transparent"
                        BorderThickness="0" Padding="12,8" VerticalAlignment="Center">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE72B;" FontSize="18" Foreground="White" />
                </Button>
                <TextBlock Grid.Column="1" Text="Invitation" Foreground="White" FontSize="18"
                           FontWeight="SemiBold" VerticalAlignment="Center" />
            </Grid>
            <ScrollViewer Grid.Row="1">
                <StackPanel Padding="24" HorizontalAlignment="Center" MaxWidth="420" VerticalAlignment="Center">
                    <Grid Width="120" Height="120" Margin="0,24,0,16" HorizontalAlignment="Center">
                        <Ellipse x:Name="InviteAvatarFallback" Fill="{StaticResource AppCardBrush}" />
                        <TextBlock x:Name="InviteAvatarInitial" Foreground="White" FontSize="48"
                                   FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <Ellipse x:Name="InviteAvatarImage" Visibility="Collapsed" />
                    </Grid>
                    <TextBlock x:Name="InviteTitle" Text="" Foreground="White" FontSize="22"
                               FontWeight="SemiBold" TextWrapping="Wrap" HorizontalAlignment="Center"
                               TextAlignment="Center" />
                    <TextBlock x:Name="InviteSubtitle" Text="" Foreground="{StaticResource AppSubtleTextBrush}"
                               FontSize="14" TextWrapping="Wrap" HorizontalAlignment="Center"
                               TextAlignment="Center" Margin="0,4,0,0" />
                    <TextBlock x:Name="InviteUserId" Text="" Foreground="{StaticResource AppFaintTextBrush}"
                               FontSize="13" TextWrapping="Wrap" HorizontalAlignment="Center"
                               TextAlignment="Center" Margin="0,4,0,0" />

                    <Button x:Name="InviteAcceptButton" Click="InviteAcceptButton_Click"
                            HorizontalAlignment="Stretch" Margin="0,32,0,0" Padding="0,14"
                            Background="{StaticResource AppAccentBrush}" Foreground="White" BorderThickness="0">
                        <TextBlock Text="Start chatting" FontSize="15" HorizontalAlignment="Center" />
                    </Button>
                    <Button x:Name="InviteDeclineButton" Click="InviteDeclineButton_Click"
                            HorizontalAlignment="Stretch" Margin="0,12,0,0" Padding="0,12"
                            Background="{StaticResource AppCardBrush}" Foreground="White" BorderThickness="0">
                        <TextBlock Text="Decline" FontSize="15" HorizontalAlignment="Center" />
                    </Button>

                    <ProgressRing x:Name="InviteProgress" IsActive="False" Width="28" Height="28"
                                  Foreground="{StaticResource AppAccentBrush}" Margin="0,16,0,0" />
                    <TextBlock x:Name="InviteStatus" Text="" Foreground="#FF6B6B" FontSize="13"
                               TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"
                               Margin="0,8,0,0" Visibility="Collapsed" />
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ========================= ADD ROOM ========================= -->
        <Grid x:Name="AddRoomPanel" Background="{StaticResource AppBackgroundBrush}" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Background="{StaticResource AppPanelBrush}" Padding="6,8" Height="64">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Click="AddRoomCloseButton_Click" Background="Transparent"
                        BorderThickness="0" Padding="12,8" VerticalAlignment="Center">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE72B;" FontSize="18" Foreground="White" />
                </Button>
                <TextBlock Grid.Column="1" Text="Add room" Foreground="White" FontSize="17"
                           FontWeight="SemiBold" VerticalAlignment="Center" />
            </Grid>

            <!-- Top controls -->
            <StackPanel Grid.Row="1" Padding="16,12">
                <Button x:Name="CreateNewRoomButton" Click="CreateNewRoomButton_Click"
                        HorizontalAlignment="Stretch" Padding="0,12"
                        Background="{StaticResource AppCardBrush}" Foreground="White"
                        FontSize="15" FontWeight="SemiBold" BorderThickness="0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE710;" FontSize="16"
                                  Foreground="White" VerticalAlignment="Center" />
                        <TextBlock Text="Create a new room" Margin="8,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <TextBlock Text="DIRECT MESSAGE" Foreground="{StaticResource AppFaintTextBrush}"
                           FontSize="11" FontWeight="SemiBold" Margin="2,20,0,4" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="DirectMessageBox"
                             PlaceholderText="@user:server.org"
                             Background="{StaticResource AppCardBrush}" BorderThickness="0"
                             VerticalAlignment="Center" KeyDown="DirectMessageBox_KeyDown" />
                    <Button Grid.Column="1" Content="Message" Click="StartDirectChatButton_Click"
                            Margin="8,0,0,0" Padding="14,9"
                            Background="{StaticResource AppAccentBrush}" Foreground="White"
                            BorderThickness="0" />
                </Grid>

                <TextBlock Text="JOIN BY ADDRESS" Foreground="{StaticResource AppFaintTextBrush}"
                           FontSize="11" FontWeight="SemiBold" Margin="2,20,0,4" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="JoinAddressBox"
                             PlaceholderText="#room:server.org or !id:server.org"
                             Background="{StaticResource AppCardBrush}" BorderThickness="0"
                             VerticalAlignment="Center" KeyDown="JoinAddressBox_KeyDown" />
                    <Button Grid.Column="1" Content="Join" Click="JoinAddressButton_Click"
                            Margin="8,0,0,0" Padding="18,9"
                            Background="{StaticResource AppAccentBrush}" Foreground="White"
                            BorderThickness="0" />
                </Grid>

                <TextBlock Text="BROWSE PUBLIC ROOMS" Foreground="{StaticResource AppFaintTextBrush}"
                           FontSize="11" FontWeight="SemiBold" Margin="2,20,0,4" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0" x:Name="DirectorySearchBox"
                             PlaceholderText="Search (leave empty to list popular rooms)"
                             Background="{StaticResource AppCardBrush}" BorderThickness="0"
                             VerticalAlignment="Center" KeyDown="DirectorySearchBox_KeyDown" />
                    <Button Grid.Column="1" Click="DirectorySearchButton_Click"
                            Margin="8,0,0,0" Padding="14,9"
                            Background="{StaticResource AppAccentBrush}" Foreground="White"
                            BorderThickness="0">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE721;" FontSize="16" Foreground="White" />
                    </Button>
                </Grid>

                <Grid Margin="0,12,0,0">
                    <ProgressRing x:Name="AddRoomProgress" Width="24" Height="24"
                                  Foreground="{StaticResource AppAccentBrush}" IsActive="False"
                                  HorizontalAlignment="Left" />
                    <TextBlock x:Name="AddRoomStatus" Foreground="{StaticResource AppSubtleTextBrush}"
                               FontSize="12" TextWrapping="Wrap" VerticalAlignment="Center"
                               Visibility="Collapsed" />
                </Grid>
            </StackPanel>

            <!-- Directory results -->
            <ListView Grid.Row="2" x:Name="PublicRoomsList" SelectionMode="None"
                      IsItemClickEnabled="True" ItemClick="PublicRoomsList_ItemClick"
                      ItemsSource="{x:Bind PublicRooms}"
                      ScrollViewer.HorizontalScrollMode="Disabled">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="MinHeight" Value="0" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="14,10" Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid Grid.Column="0" Width="44" Height="44" Margin="0,0,12,0">
                                <Ellipse Fill="{Binding AvatarBrush}" />
                                <TextBlock Text="{Binding AvatarInitial}" Foreground="White"
                                           FontSize="18" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Grid>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding DisplayName}" Foreground="White"
                                           FontSize="15" FontWeight="SemiBold"
                                           TextTrimming="CharacterEllipsis" MaxLines="1" />
                                <TextBlock Text="{Binding TopicLine}" Foreground="{StaticResource AppSubtleTextBrush}"
                                           FontSize="12" TextTrimming="CharacterEllipsis" MaxLines="1"
                                           Margin="0,2,0,0" />
                                <TextBlock Text="{Binding MembersText}" Foreground="{StaticResource AppFaintTextBrush}"
                                           FontSize="11" Margin="0,2,0,0" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- ======================= CREATE ROOM ======================= -->
        <Grid x:Name="CreateRoomPanel" Background="#CC000000" Visibility="Collapsed">
            <Border Background="{StaticResource AppPanelBrush}" CornerRadius="12"
                    MaxWidth="380" Margin="24" Padding="20" VerticalAlignment="Center"
                    HorizontalAlignment="Stretch">
                <StackPanel>
                    <TextBlock Text="New room" Foreground="White" FontSize="20" FontWeight="SemiBold" />
                    <TextBox x:Name="NewRoomName" PlaceholderText="Room name" Margin="0,16,0,12"
                             Background="{StaticResource AppCardBrush}" BorderThickness="0" />
                    <ToggleSwitch x:Name="NewRoomPublic" Header="Public room" OffContent="Private"
                                  OnContent="Public" Foreground="White" />
                    <TextBlock x:Name="CreateRoomError" Foreground="#FF6B6B" FontSize="13"
                               TextWrapping="Wrap" Visibility="Collapsed" Margin="0,8,0,0" />
                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Cancel" Click="CreateRoomCancel_Click"
                                HorizontalAlignment="Stretch" Margin="0,0,6,0"
                                Background="{StaticResource AppCardBrush}" Foreground="White" />
                        <Button Grid.Column="1" Content="Create" Click="CreateRoomConfirm_Click"
                                HorizontalAlignment="Stretch" Margin="6,0,0,0"
                                Background="{StaticResource AppAccentBrush}" Foreground="White" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ========================= SETTINGS ========================= -->
        <Grid x:Name="SettingsPanel" Background="{StaticResource AppBackgroundBrush}" Visibility="Collapsed">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Background="{StaticResource AppPanelBrush}" Padding="6,8" Height="64">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" Click="SettingsCloseButton_Click" Background="Transparent"
                        BorderThickness="0" Padding="12,8" VerticalAlignment="Center">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE72B;" FontSize="18" Foreground="White" />
                </Button>
                <TextBlock Grid.Column="1" x:Name="SettingsTitle" Text="Account" Foreground="White" FontSize="18"
                           FontWeight="SemiBold" VerticalAlignment="Center" />
            </Grid>
            <!-- ===== Tab 0: User (account, sign out, version) ===== -->
            <ScrollViewer x:Name="SettingsTab0" Grid.Row="1" Visibility="Visible">
                <StackPanel Padding="20" MaxWidth="480">
                    <TextBlock Text="ACCOUNT" Foreground="{StaticResource AppFaintTextBrush}"
                               FontSize="11" FontWeight="SemiBold" Margin="0,0,0,12" />
                    <Grid Width="72" Height="72" Margin="0,0,0,12" HorizontalAlignment="Left">
                        <Ellipse x:Name="AccountAvatarFallback" Fill="{StaticResource AppCardBrush}" />
                        <TextBlock x:Name="AccountAvatarInitial" Foreground="White" FontSize="28"
                                   FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <Ellipse x:Name="AccountAvatarImage" Visibility="Collapsed" />
                    </Grid>
                    <TextBlock x:Name="SettingsUserId" Text="" Foreground="White" FontSize="15" />
                    <TextBlock x:Name="SettingsDeviceId" Text="" Foreground="{StaticResource AppSubtleTextBrush}"
                               FontSize="13" Margin="0,4,0,0" />
                    <TextBlock x:Name="SettingsHomeserver" Text="" Foreground="{StaticResource AppSubtleTextBrush}"
                               FontSize="13" Margin="0,4,0,0" />

                    <Button x:Name="LogoutButton" Content="Sign out" Click="LogoutButton_Click"
                            HorizontalAlignment="Stretch" Padding="0,12" Margin="0,32,0,0"
                            Background="#3A1414" Foreground="#FF6B6B" FontWeight="SemiBold" />

                    <TextBlock Text="ABOUT" Foreground="{StaticResource AppFaintTextBrush}"
                               FontSize="11" FontWeight="SemiBold" Margin="0,32,0,8" />
                    <TextBlock x:Name="SettingsBuild" Text="" Foreground="{StaticResource AppFaintTextBrush}"
                               FontSize="12" />
                </StackPanel>
            </ScrollViewer>

            <!-- ===== Tab 1: Look and feel (accent, notifications, live tile) ===== -->
            <ScrollViewer x:Name="SettingsTab1" Grid.Row="1" Visibility="Collapsed">
                <StackPanel Padding="20" MaxWidth="480">
                    <TextBlock Text="APPEARANCE" Foreground="{StaticResource AppFaintTextBrush}"
                               FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <ToggleSwitch x:Name="UseAccentToggle" Header="Use system accent color"
                                  OffContent="UniMatrix green" OnContent="System accent"
                                  Foreground="White" Toggled="UseAccentToggle_Toggled" />

                    <TextBlock Text="NOTIFICATIONS" Foreground="{StaticResource AppFaintTextBrush}"
                               FontSize="11" FontWeight="SemiBold" Margin="0,28,0,8" />
                    <ToggleSwitch x:Name="NotifyDirectToggle" Header="Notify for direct messages"
                                  OffContent="Off" OnContent="On"
                                  Foreground="White" Toggled="NotifyDirectToggle_Toggled" />
                    <ToggleSwitch x:Name="NotifyGroupsToggle" Header="Notify for group rooms"
                                  OffContent="Off" OnContent="On"
                                  Foreground="White" Toggled="NotifyGroupsToggle_Toggled" Margin="0,8,0,0" />
                    <TextBlock Text="Checked about every 15 minutes in the background."
                               Foreground="{StaticResource AppFaintTextBrush}" FontSize="12"
                               Margin="0,4,0,0" TextWrapping="Wrap" />

                    <TextBlock Text="Live tile" Foreground="White" FontSize="14" Margin="0,16,0,0" />
                    <ComboBox x:Name="LiveTileModeCombo" HorizontalAlignment="Stretch"
                              Margin="0,6,0,0" SelectionChanged="LiveTileModeCombo_SelectionChanged">
                        <ComboBoxItem Content="Off" />
                        <ComboBoxItem Content="All messages" />
                        <ComboBoxItem Content="Direct messages only" />
                        <ComboBoxItem Content="Group rooms only" />
                    </ComboBox>
                    <TextBlock Text="Shows the latest matching message on the Start screen tile."
                               Foreground="{StaticResource AppFaintTextBrush}" FontSize="12"
                               Margin="0,4,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </ScrollViewer>

            <!-- ===== Tab 2: Security (key backup + device verification) ===== -->
            <ScrollViewer x:Name="SettingsTab2" Grid.Row="1" Visibility="Collapsed">
                <StackPanel Padding="20" MaxWidth="480">
                    <TextBlock Text="ENCRYPTION &amp; BACKUP" Foreground="{StaticResource AppFaintTextBrush}"
                               FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock x:Name="BackupStatusText" Text="Checking key backup…"
                               Foreground="{StaticResource AppSubtleTextBrush}" FontSize="13"
                               Margin="0,0,0,12" TextWrapping="Wrap" />
                    <Button x:Name="SetupRecoveryButton" Content="Set up key backup &amp; recovery"
                            Click="SetupRecoveryButton_Click"
                            HorizontalAlignment="Stretch" Padding="0,12" Margin="0,0,0,8"
                            Background="{StaticResource AppCardBrush}" Foreground="White" FontWeight="SemiBold" />
                    <Button x:Name="EnterRecoveryButton" Content="Restore from recovery key"
                            Click="EnterRecoveryButton_Click"
                            HorizontalAlignment="Stretch" Padding="0,12"
                            Background="{StaticResource AppCardBrush}" Foreground="White" FontWeight="SemiBold" />
                    <TextBlock Text="A recovery key (or passphrase) lets you restore your encrypted message history after signing in on a new device."
                               Foreground="{StaticResource AppFaintTextBrush}" FontSize="12"
                               Margin="0,6,0,0" TextWrapping="Wrap" />

                    <TextBlock Text="DEVICE VERIFICATION" Foreground="{StaticResource AppFaintTextBrush}"
                               FontSize="11" FontWeight="SemiBold" Margin="0,28,0,8" />
                    <TextBlock x:Name="CrossSigningStatusText" Text="Checking verification status…"
                               Foreground="{StaticResource AppSubtleTextBrush}" FontSize="13"
                               Margin="0,0,0,12" TextWrapping="Wrap" />
                    <Button x:Name="VerifySessionButton" Content="Verify this session"
                            Click="VerifySessionButton_Click"
                            HorizontalAlignment="Stretch" Padding="0,12"
                            Background="{StaticResource AppCardBrush}" Foreground="White" FontWeight="SemiBold" />
                    <TextBlock Text="Verifying this session cross-signs it with your account so your other devices (and contacts) trust it."
                               Foreground="{StaticResource AppFaintTextBrush}" FontSize="12"
                               Margin="0,6,0,0" TextWrapping="Wrap" />

                    <Grid Margin="0,28,0,8">
                        <TextBlock Text="YOUR SESSIONS" Foreground="{StaticResource AppFaintTextBrush}"
                                   FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </Grid>
                    <Button x:Name="ManageSessionsButton" Content="Manage sessions"
                            Click="ManageSessionsButton_Click"
                            HorizontalAlignment="Stretch" Padding="0,12"
                            Background="{StaticResource AppCardBrush}" Foreground="White" FontWeight="SemiBold" />
                    <TextBlock Text="See everywhere you're signed in. Verify a session to confirm it's really yours, or remove ones you don't recognise."
                               Foreground="{StaticResource AppFaintTextBrush}" FontSize="12"
                               Margin="0,6,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </ScrollViewer>

            <!-- ===== Tab 3: Maintenance (history, storage, wipe) ===== -->
            <ScrollViewer x:Name="SettingsTab3" Grid.Row="1" Visibility="Collapsed">
                <StackPanel Padding="20" MaxWidth="480">
                    <TextBlock Text="HISTORY" Foreground="{StaticResource AppFaintTextBrush}"
                               FontSize="11" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock Text="Days of history to load per room" Foreground="White" FontSize="14" />
                    <Slider x:Name="HistoryDaysSlider" Minimum="7" Maximum="365" StepFrequency="1"
                            TickFrequency="30" ValueChanged="HistoryDaysSlider_ValueChanged"
                            Foreground="{StaticResource AppAccentBrush}" Margin="0,8,0,0" />
                    <TextBlock x:Name="HistoryDaysValue" Text="" Foreground="{StaticResource AppSubtleTextBrush}"
                               FontSize="13" />
                    <TextBlock Text="Quiet rooms fall back to the last 50 messages."
                               Foreground="{StaticResource AppFaintTextBrush}" FontSize="12"
                               Margin="0,4,0,0" TextWrapping="Wrap" />

                    <TextBlock Text="MAINTENANCE" Foreground="{StaticResource AppFaintTextBrush}"
                               FontSize="11" FontWeight="SemiBold" Margin="0,28,0,8" />
                    <TextBlock x:Name="StorageUsage" Text="Calculating storage…"
                               Foreground="{StaticResource AppSubtleTextBrush}" FontSize="13"
                               Margin="0,0,0,12" TextWrapping="Wrap" />
                    <Button x:Name="WipeCacheButton" Content="Wipe cache &amp; resync"
                            Click="WipeCacheButton_Click"
                            HorizontalAlignment="Stretch" Padding="0,12"
                            Background="#3A2A14" Foreground="#FFB86B" FontWeight="SemiBold" />
                    <TextBlock Text="Clears all locally cached rooms and messages, then re-downloads everything from the server. You stay signed in."
                               Foreground="{StaticResource AppFaintTextBrush}" FontSize="12"
                               Margin="0,6,0,0" TextWrapping="Wrap" />
                </StackPanel>
            </ScrollViewer>

            <!-- ===== Bottom tab bar (accent-highlighted active tab) ===== -->
            <Grid Grid.Row="2" Background="{StaticResource AppPanelBrush}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button x:Name="SettingsNav0" Grid.Column="0" Click="SettingsNav0_Click"
                        Background="{StaticResource AppAccentBrush}" BorderThickness="0"
                        HorizontalAlignment="Stretch" Padding="0,12"
                        ToolTipService.ToolTip="Account">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE77B;" FontSize="20" Foreground="White" />
                </Button>
                <Button x:Name="SettingsNav1" Grid.Column="1" Click="SettingsNav1_Click"
                        Background="Transparent" BorderThickness="0"
                        HorizontalAlignment="Stretch" Padding="0,12"
                        ToolTipService.ToolTip="Look &amp; feel">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE790;" FontSize="20" Foreground="White" />
                </Button>
                <Button x:Name="SettingsNav2" Grid.Column="2" Click="SettingsNav2_Click"
                        Background="Transparent" BorderThickness="0"
                        HorizontalAlignment="Stretch" Padding="0,12"
                        ToolTipService.ToolTip="Security">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xEA18;" FontSize="20" Foreground="White" />
                </Button>
                <Button x:Name="SettingsNav3" Grid.Column="3" Click="SettingsNav3_Click"
                        Background="Transparent" BorderThickness="0"
                        HorizontalAlignment="Stretch" Padding="0,12"
                        ToolTipService.ToolTip="Maintenance">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE90F;" FontSize="20" Foreground="White" />
                </Button>
            </Grid>
        </Grid>

        <!-- ========================= DEBUG OVERLAY ========================= -->
        <!-- A terminal-style log that fills line by line. Toggle with the bug button. -->
        <Grid x:Name="DebugOverlay" Visibility="Collapsed" Background="#E6000000">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid Grid.Row="0" Background="#111111" Padding="12,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Debug log" Foreground="White"
                           FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" />
                <Button Grid.Column="1" Content="Save" Click="DebugSave_Click"
                        Background="Transparent" Foreground="#33FF66" BorderThickness="0"
                        Padding="10,6" VerticalAlignment="Center" />
                <Button Grid.Column="2" Content="Clear" Click="DebugClear_Click"
                        Background="Transparent" Foreground="#BBBBBB" BorderThickness="0"
                        Padding="10,6" VerticalAlignment="Center" />
                <Button Grid.Column="3" Content="Close" Click="DebugToggle_Click"
                        Background="Transparent" Foreground="#BBBBBB" BorderThickness="0"
                        Padding="10,6" VerticalAlignment="Center" />
            </Grid>
            <ScrollViewer Grid.Row="1" x:Name="DebugScroll" VerticalScrollBarVisibility="Auto"
                          Padding="12,8">
                <TextBlock x:Name="DebugText" Foreground="#33FF66" FontFamily="Consolas"
                           FontSize="12" TextWrapping="Wrap" IsTextSelectionEnabled="True" />
            </ScrollViewer>
        </Grid>

        <!-- Initial-sync progress bar, pinned to the bottom of the screen. -->
        <StackPanel x:Name="SyncProgressPanel" VerticalAlignment="Bottom"
                    Background="{StaticResource AppPanelBrush}" Padding="14,8"
                    Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="SyncProgressText" Grid.Column="0" Text="Syncing your account…"
                           Foreground="{StaticResource AppSubtleTextBrush}"
                           FontSize="12" Margin="0,0,0,4" VerticalAlignment="Center" />
                <Button x:Name="SyncCancelButton" Grid.Column="1" Content="Cancel"
                        Click="SyncCancelButton_Click" Visibility="Collapsed"
                        Background="Transparent" Foreground="{StaticResource AppAccentBrush}"
                        BorderThickness="0" Padding="10,2" FontSize="12" VerticalAlignment="Center" />
            </Grid>
            <ProgressBar x:Name="SyncProgressBar" IsIndeterminate="True"
                         Foreground="{StaticResource AppAccentBrush}" />
        </StackPanel>

        <!-- ===================== SECURITY: KEY-BACKUP SETUP ===================== -->
        <Grid x:Name="SecuritySetupPanel" Background="#CC000000" Visibility="Collapsed">
            <Border Background="{StaticResource AppPanelBrush}" CornerRadius="12"
                    MaxWidth="400" Margin="24" Padding="20" VerticalAlignment="Center"
                    HorizontalAlignment="Stretch">
                <StackPanel>
                    <TextBlock Text="Set up key backup" Foreground="White" FontSize="20" FontWeight="SemiBold" />

                    <!-- Input phase -->
                    <StackPanel x:Name="SecuritySetupInput">
                        <TextBlock Text="A secure backup of your message keys is stored on the server, protected by a recovery key. You can also add a passphrase you'll remember."
                                   Foreground="{StaticResource AppSubtleTextBrush}" FontSize="13"
                                   TextWrapping="Wrap" Margin="0,12,0,0" />
                        <PasswordBox x:Name="SetupPassphraseBox" PlaceholderText="Passphrase (optional)"
                                     Margin="0,16,0,0" Background="{StaticResource AppCardBrush}" BorderThickness="0" />
                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="Cancel" Click="SecuritySetupCancel_Click"
                                    HorizontalAlignment="Stretch" Margin="0,0,6,0"
                                    Background="{StaticResource AppCardBrush}" Foreground="White" />
                            <Button Grid.Column="1" Content="Create" Click="SecuritySetupCreate_Click"
                                    HorizontalAlignment="Stretch" Margin="6,0,0,0"
                                    Background="{StaticResource AppAccentBrush}" Foreground="White" />
                        </Grid>
                    </StackPanel>

                    <!-- Result phase -->
                    <StackPanel x:Name="SecuritySetupResult" Visibility="Collapsed">
                        <TextBlock Text="Write down this recovery key and keep it safe. You'll need it to restore your history on another device. It won't be shown again."
                                   Foreground="{StaticResource AppAccentBrush}" FontSize="13"
                                   TextWrapping="Wrap" Margin="0,12,0,0" />
                        <TextBox x:Name="RecoveryKeyDisplay" IsReadOnly="True" TextWrapping="Wrap"
                                 Margin="0,12,0,0" Background="{StaticResource AppCardBrush}" Foreground="White"
                                 BorderThickness="0" FontFamily="Consolas" />
                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="Copy" Click="RecoveryKeyCopy_Click"
                                    HorizontalAlignment="Stretch" Margin="0,0,6,0"
                                    Background="{StaticResource AppCardBrush}" Foreground="White" />
                            <Button Grid.Column="1" Content="Done" Click="SecuritySetupDone_Click"
                                    HorizontalAlignment="Stretch" Margin="6,0,0,0"
                                    Background="{StaticResource AppAccentBrush}" Foreground="White" />
                        </Grid>
                    </StackPanel>

                    <StackPanel x:Name="SecuritySetupProgress" Orientation="Horizontal" Visibility="Collapsed"
                                Margin="0,16,0,0" HorizontalAlignment="Center">
                        <ProgressRing IsActive="True" Width="20" Height="20" Foreground="{StaticResource AppAccentBrush}" />
                        <TextBlock x:Name="SecuritySetupProgressText" Text="Working…" Margin="10,0,0,0"
                                   VerticalAlignment="Center" Foreground="White" FontSize="13" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===================== SECURITY: RESTORE FROM RECOVERY ===================== -->
        <Grid x:Name="RecoveryPanel" Background="#CC000000" Visibility="Collapsed">
            <Border Background="{StaticResource AppPanelBrush}" CornerRadius="12"
                    MaxWidth="400" Margin="24" Padding="20" VerticalAlignment="Center"
                    HorizontalAlignment="Stretch">
                <StackPanel>
                    <TextBlock Text="Restore encrypted history" Foreground="White" FontSize="20" FontWeight="SemiBold" />
                    <TextBlock Text="Enter your recovery key or passphrase to unlock the key backup and decrypt your message history."
                               Foreground="{StaticResource AppSubtleTextBrush}" FontSize="13"
                               TextWrapping="Wrap" Margin="0,12,0,0" />
                    <TextBox x:Name="RecoveryInput" PlaceholderText="Recovery key or passphrase"
                             Margin="0,16,0,0" Background="{StaticResource AppCardBrush}" Foreground="White"
                             BorderThickness="0" TextWrapping="Wrap" AcceptsReturn="False" />
                    <Grid Margin="0,16,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="Cancel" Click="RecoveryCancel_Click"
                                HorizontalAlignment="Stretch" Margin="0,0,6,0"
                                Background="{StaticResource AppCardBrush}" Foreground="White" />
                        <Button Grid.Column="1" Content="Restore" Click="RecoveryConfirm_Click"
                                HorizontalAlignment="Stretch" Margin="6,0,0,0"
                                Background="{StaticResource AppAccentBrush}" Foreground="White" />
                    </Grid>
                    <StackPanel x:Name="RecoveryProgress" Orientation="Horizontal" Visibility="Collapsed"
                                Margin="0,16,0,0" HorizontalAlignment="Center">
                        <ProgressRing IsActive="True" Width="20" Height="20" Foreground="{StaticResource AppAccentBrush}" />
                        <TextBlock x:Name="RecoveryProgressText" Text="Restoring…" Margin="10,0,0,0"
                                   VerticalAlignment="Center" Foreground="White" FontSize="13" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===================== FULL-SCREEN IMAGE VIEWER ===================== -->
        <!-- Top-most overlay (last child) so it covers everything. Tapping the
             backdrop or the close button dismisses it. -->
        <Grid x:Name="ImageViewerPanel" Background="#F0000000" Visibility="Collapsed"
              Tapped="ImageViewerPanel_Tapped" SizeChanged="ImageViewerPanel_SizeChanged">
            <ScrollViewer x:Name="ImageViewerScroll" ZoomMode="Enabled"
                          MinZoomFactor="1" MaxZoomFactor="6"
                          HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollMode="Auto" VerticalScrollMode="Auto"
                          HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                <Image x:Name="ImageViewerImage" Stretch="Uniform" />
            </ScrollViewer>
            <ProgressRing x:Name="ImageViewerSpinner" IsActive="False" Width="48" Height="48"
                          Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
            <Button x:Name="ImageViewerCloseButton" Click="ImageViewerCloseButton_Click"
                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,12,12,0"
                    Background="#80000000" BorderThickness="0" Padding="12,12">
                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE711;" FontSize="18" Foreground="White" />
            </Button>
        </Grid>

        <!-- ===================== CALL OVERLAY ===================== -->
        <!-- Top-most overlay for an active or incoming audio call. The same panel serves both:
             AcceptDeclinePanel shows while an incoming call is ringing, then it collapses and
             only the Hang up button remains for the connected call. -->
        <Grid x:Name="CallOverlay" Background="#F0101418" Visibility="Collapsed">
            <!-- Remote camera fills the screen during a connected video call. It sits behind the
                 (transparent) controls grid and the self-view PiP. RealTimePlayback minimizes
                 buffering so the remote view stays live. Shown only once a remote video track arrives. -->
            <MediaElement x:Name="PeerVideo" Stretch="UniformToFill" Visibility="Collapsed"
                          RealTimePlayback="True" />
            <Grid MaxWidth="360" HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                  Margin="24,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Timer at ~25% height, with a phone glyph in front. -->
                <StackPanel x:Name="CallTimerPanel" Grid.Row="0" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Bottom"
                            Visibility="Collapsed">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE717;" FontSize="18"
                              Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBlock x:Name="CallTimerText" Text="" Foreground="White"
                               FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>

                <!-- Avatar + name + status, centered (~50% height). Hidden once remote video shows. -->
                <StackPanel x:Name="CallInfoPanel" Grid.Row="1" Grid.RowSpan="2" HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <Grid Width="96" Height="96" HorizontalAlignment="Center">
                        <Ellipse x:Name="CallAvatarFallback" Fill="{StaticResource AppCardBrush}" />
                        <TextBlock x:Name="CallAvatarInitial" Foreground="White" FontSize="40"
                                   FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        <Ellipse x:Name="CallAvatarImage" Visibility="Collapsed" />
                    </Grid>
                    <TextBlock x:Name="CallPeerName" Text="" Foreground="White" FontSize="22"
                               FontWeight="SemiBold" HorizontalAlignment="Center"
                               TextAlignment="Center" TextWrapping="Wrap" Margin="0,20,0,4" />
                    <TextBlock x:Name="CallStatusText" Text="" Foreground="{StaticResource AppSubtleTextBrush}"
                               FontSize="15" HorizontalAlignment="Center" />
                </StackPanel>

                <!-- Buttons at ~75% height. -->
                <Grid Grid.Row="3" VerticalAlignment="Top" HorizontalAlignment="Stretch">
                    <!-- Incoming-call accept/decline -->
                    <Grid x:Name="CallAcceptDeclinePanel" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="CallDeclineButton" Grid.Column="0" Click="CallDeclineButton_Click"
                                HorizontalAlignment="Stretch" Margin="0,0,6,0" Padding="16,14"
                                Background="#3A1414" Foreground="#FF6B6B" BorderThickness="0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE778;" FontSize="18"
                                          Foreground="#FF6B6B" VerticalAlignment="Center" />
                                <TextBlock x:Name="CallDeclineLabel" Text="Decline" Margin="8,0,0,0" VerticalAlignment="Center" FontSize="15" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="CallAcceptButton" Grid.Column="1" Click="CallAcceptButton_Click"
                                HorizontalAlignment="Stretch" Margin="6,0,0,0" Padding="16,14"
                                Background="#14401C" Foreground="#4CD964" BorderThickness="0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE717;" FontSize="18"
                                          Foreground="#4CD964" VerticalAlignment="Center" />
                                <TextBlock x:Name="CallAcceptLabel" Text="Accept" Margin="8,0,0,0" VerticalAlignment="Center" FontSize="15" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Active call: mute + hang up, side by side. -->
                    <Grid x:Name="CallActivePanel" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="CallMuteButton" Grid.Column="0" Click="CallMuteButton_Click"
                                HorizontalAlignment="Stretch" Margin="0,0,6,0" Padding="16,14"
                                Background="{StaticResource AppCardBrush}" Foreground="White" BorderThickness="0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <FontIcon x:Name="CallMuteIcon" FontFamily="Segoe MDL2 Assets" Glyph="&#xE720;"
                                          FontSize="18" VerticalAlignment="Center" />
                                <TextBlock x:Name="CallMuteLabel" Text="Mute" Margin="8,0,0,0"
                                           VerticalAlignment="Center" FontSize="15" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="CallHangupButton" Grid.Column="1" Click="CallHangupButton_Click"
                                HorizontalAlignment="Stretch" Margin="6,0,0,0" Padding="16,14"
                                Background="#3A1414" Foreground="#FF6B6B" BorderThickness="0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE778;" FontSize="18"
                                          Foreground="#FF6B6B" VerticalAlignment="Center" />
                                <TextBlock Text="Hang up" Margin="8,0,0,0" VerticalAlignment="Center" FontSize="15" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </Grid>

            <!-- Local self-preview (picture-in-picture). Hidden until a video call/preview starts;
                 a MediaElement is the render target for the WebRTC self video track via
                 MediaElementMaker.Bind. RealTimePlayback minimizes the element's buffering so the
                 self-view tracks the camera live instead of lagging ~2s behind. -->
            <Border x:Name="SelfVideoBorder" Width="108" Height="144" Visibility="Collapsed"
                    HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,24,16,0"
                    CornerRadius="8" Background="#22000000" BorderBrush="#33FFFFFF" BorderThickness="1">
                <MediaElement x:Name="SelfVideo" Stretch="UniformToFill" RealTimePlayback="True" />
            </Border>
        </Grid>

        <!-- Full-screen "Your sessions" manager. Opened from Security settings; lists every device
             signed in to the account with a verified/unverified badge and verify/rename/remove
             actions. Sessions are only fetched when this opens (or when refreshed), not on every
             visit to the Security tab. -->
        <Grid x:Name="SessionsOverlay" Background="{StaticResource AppBackgroundBrush}" Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Header: back + title + refresh -->
                <Grid Grid.Row="0" Background="{StaticResource AppPanelBrush}" Padding="8,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Click="SessionsCloseButton_Click"
                            Background="Transparent" BorderThickness="0" Padding="10,6" VerticalAlignment="Center">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE72B;" FontSize="18" Foreground="White" />
                    </Button>
                    <TextBlock Grid.Column="1" Text="Your sessions" Foreground="White" FontSize="18"
                               FontWeight="SemiBold" VerticalAlignment="Center" Margin="6,0,0,0" />
                    <Button x:Name="RefreshDevicesButton" Grid.Column="2" Click="RefreshDevicesButton_Click"
                            Background="Transparent" BorderThickness="0" Padding="10,6" VerticalAlignment="Center">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE72C;" FontSize="18" Foreground="White" />
                    </Button>
                </Grid>

                <!-- Body: status line + scrollable device cards -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollMode="Disabled">
                    <StackPanel Padding="20" MaxWidth="480">
                        <Button x:Name="SignOutOthersButton" Content="Sign out all other sessions"
                                Click="SignOutOthersButton_Click"
                                HorizontalAlignment="Stretch" Padding="0,12" Margin="0,0,0,12"
                                Background="#5A1F1F" Foreground="White" FontWeight="SemiBold" />
                        <TextBlock x:Name="DeviceListStatus" Text="Loading sessions…"
                                   Foreground="{StaticResource AppSubtleTextBrush}" FontSize="13"
                                   Margin="0,0,0,12" TextWrapping="Wrap" />
                        <StackPanel x:Name="DeviceListPanel" />
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- Device verification (SAS / emoji). Shown when a verification request arrives or when the
             user starts one from Security settings. Three stages: request accept/decline, emoji
             comparison, then a final status line. -->
        <Grid x:Name="VerifyOverlay" Background="#F0101418" Visibility="Collapsed">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollMode="Disabled">
                <StackPanel MaxWidth="400" Margin="24,40" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE72E;" FontSize="40"
                              Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,12" />
                    <TextBlock x:Name="VerifyTitle" Text="Verify device" Foreground="White" FontSize="22"
                               FontWeight="SemiBold" HorizontalAlignment="Center" TextAlignment="Center" />
                    <TextBlock x:Name="VerifySubtitle" Text="" Foreground="{StaticResource AppSubtleTextBrush}"
                               FontSize="14" HorizontalAlignment="Center" TextAlignment="Center"
                               TextWrapping="Wrap" Margin="0,6,0,18" />

                    <!-- Stage 1: incoming request accept/decline -->
                    <Grid x:Name="VerifyRequestPanel" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Click="VerifyDeclineButton_Click"
                                HorizontalAlignment="Stretch" Margin="0,0,6,0" Padding="16,14"
                                Background="#3A1414" Foreground="#FF6B6B" BorderThickness="0">
                            <TextBlock Text="Decline" HorizontalAlignment="Center" FontSize="15" />
                        </Button>
                        <Button Grid.Column="1" Click="VerifyAcceptButton_Click"
                                HorizontalAlignment="Stretch" Margin="6,0,0,0" Padding="16,14"
                                Background="#14401C" Foreground="#4CD964" BorderThickness="0">
                            <TextBlock Text="Accept" HorizontalAlignment="Center" FontSize="15" />
                        </Button>
                    </Grid>

                    <!-- Stage 2: emoji comparison -->
                    <StackPanel x:Name="VerifyEmojiPanel" Visibility="Collapsed">
                        <TextBlock Text="Confirm the emoji below appear in the same order on both devices."
                                   Foreground="{StaticResource AppSubtleTextBrush}" FontSize="14"
                                   TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,16" />
                        <ItemsControl x:Name="VerifyEmojiList" HorizontalAlignment="Center">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="4" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                        <TextBlock x:Name="VerifyDecimalText" Text="" Foreground="{StaticResource AppSubtleTextBrush}"
                                   FontSize="13" HorizontalAlignment="Center" Margin="0,12,0,18" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Click="VerifyMismatchButton_Click"
                                    HorizontalAlignment="Stretch" Margin="0,0,6,0" Padding="16,14"
                                    Background="#3A1414" Foreground="#FF6B6B" BorderThickness="0">
                                <TextBlock Text="They don't match" HorizontalAlignment="Center" FontSize="14" />
                            </Button>
                            <Button Grid.Column="1" Click="VerifyMatchButton_Click"
                                    HorizontalAlignment="Stretch" Margin="6,0,0,0" Padding="16,14"
                                    Background="#14401C" Foreground="#4CD964" BorderThickness="0">
                                <TextBlock Text="They match" HorizontalAlignment="Center" FontSize="14" />
                            </Button>
                        </Grid>
                    </StackPanel>

                    <!-- Stage 3: progress / final status -->
                    <StackPanel x:Name="VerifyStatusPanel" Visibility="Collapsed">
                        <ProgressRing x:Name="VerifyProgress" IsActive="False" Width="32" Height="32"
                                      Foreground="White" Margin="0,0,0,12" />
                        <TextBlock x:Name="VerifyStatusText" Text="" Foreground="White" FontSize="15"
                                   HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" />
                        <Button x:Name="VerifyCloseButton" Click="VerifyCloseButton_Click" Margin="0,18,0,0"
                                HorizontalAlignment="Stretch" Padding="16,14"
                                Background="{StaticResource AppCardBrush}" Foreground="White" BorderThickness="0"
                                Visibility="Collapsed">
                            <TextBlock Text="Close" HorizontalAlignment="Center" FontSize="15" />
                        </Button>
                        <Button x:Name="VerifyCancelButton" Click="VerifyCancelButton_Click" Margin="0,18,0,0"
                                HorizontalAlignment="Stretch" Padding="16,14"
                                Background="#3A1414" Foreground="#FF6B6B" BorderThickness="0"
                                Visibility="Collapsed">
                            <TextBlock Text="Cancel" HorizontalAlignment="Center" FontSize="15" />
                        </Button>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

    </Grid>
</Page>
