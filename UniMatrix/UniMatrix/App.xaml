<Application
    x:Class="UniMatrix.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:UniMatrix"
    RequestedTheme="Dark">
    <Application.Resources>
        <!-- Matrix brand green. Used as the app accent throughout the UI. -->
        <SolidColorBrush x:Key="AppAccentBrush" Color="#0DBD8B" />
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#000000" />
        <SolidColorBrush x:Key="AppPanelBrush" Color="#111111" />
        <SolidColorBrush x:Key="AppCardBrush" Color="#161616" />
        <SolidColorBrush x:Key="AppSubtleTextBrush" Color="#BBBBBB" />
        <SolidColorBrush x:Key="AppFaintTextBrush" Color="#777777" />
        <SolidColorBrush x:Key="AppOwnBubbleBrush" Color="#0DBD8B" />
        <SolidColorBrush x:Key="AppOtherBubbleBrush" Color="#1E1E1E" />
    </Application.Resources>
</Application>
