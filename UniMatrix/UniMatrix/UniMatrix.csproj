  <!--
    MANAGED-RTC SPIKE — SIPSorcery NuGet path REMOVED (it can never work on this target).
    SIPSorcery only ships netstandard2.0+, and consuming netstandard2.0 requires
    TargetPlatformMinVersion >= 10.0.16299; this project is min 10.0.14393 (and the target device,
    a Lumia 930 on Windows 10 Mobile, never reaches 16299), so NuGet restore always failed with
    NU1202 and the resulting package would be undeployable anyway. The managed-WebRTC investigation
    continues via the dependency-free vendoring path instead (Services\StunProbe.cs, pure
    Windows.Networking.Sockets — no NuGet). Services\ManagedRtcProbe.cs remains as an inert stub
    (its SIPSorcery code is behind the SPIKE_MANAGED_RTC constant, which is intentionally never
    defined). Do NOT re-add a SIPSorcery PackageReference here — it will only reintroduce NU1202.
  -->
  <!--
    Windows Mobile Extensions for the UWP: provides the mobile-only contracts used at compile time,
    e.g. Windows.Phone.Devices.Notification.VibrationDevice (incoming-call ring vibration). All such
    calls are still guarded at runtime with ApiInformation so the app keeps working on desktop.
  -->
  <ItemGroup>
    <SDKReference Include="WindowsMobile, Version=10.0.16299.0">
      <Name>Windows Mobile Extensions for the UWP</Name>
    </SDKReference>
  </ItemGroup>
  <!--
    WebRTC native component (webrtc-uwp SDK, M71). Org.WebRtc.winmd carries the WinRT type
    metadata used at compile time; Org.WebRtc.dll is the native (ARMv7) implementation. For a
    NATIVE WinMD the implementation dll MUST be declared via <Implementation> so MSBuild copies
    it to the output AND doesn't try to read it as a managed assembly (doing the latter causes
    MSB3246 "no assembly manifest" and silently drops the reference -> CS0246 on every Org.* type).
    Do NOT add the dll as a separate <Content> item — that reintroduces the mis-resolution.
    The matching binaries are vendored under libs\webrtc\<Platform>\. ARM is the only arch
    harvested so far (the Lumia 930 target); x86/x64 groups are added as those arches are harvested.
  -->
  <ItemGroup Condition="'$(Platform)' == 'ARM'">
    <Reference Include="Org.WebRtc">
      <HintPath>libs\webrtc\ARM\Org.WebRtc.winmd</HintPath>
      <IsWinMDFile>true</IsWinMDFile>
      <Implementation>Org.WebRtc.dll</Implementation>
    </Reference>
  </ItemGroup>
  <!--
    libolm native library (olm.dll). Unlike Org.WebRtc this is a PLAIN native C DLL (not a WinRT
    component / WinMD), so it is consumed via P/Invoke (Services\OlmNative.cs) and only needs to
    be copied app-local as <Content>. There is no winmd and no <Implementation> element. Build it
    with external_dependencies\olm-build\build-olm-uwp.ps1 on the Windows box and harvest to
    libs\olm\ARM. ARM is the
    only arch harvested so far (the Lumia 930 target); add x86/x64 groups as those are built.

    IMPORTANT: <Link>olm.dll</Link> places the DLL at the PACKAGE ROOT. The appcontainer loader
    only resolves a P/Invoke ("olm.dll") from the package root (and declared framework packages);
    a DLL left in the libs\olm\ARM\ subfolder is NOT found and fails with ERROR_MOD_NOT_FOUND/126.

    olm.dll links the appcontainer VC++ runtime (MSVCP140_APP.dll / VCRUNTIME140_APP.dll); those
    come from the Microsoft.VCLibs.140.00 framework package, declared as a <PackageDependency> in
    Package.appxmanifest. In Release|ARM .NET Native also adds that dependency automatically.
  -->
  <ItemGroup Condition="'$(Platform)' == 'ARM'">
    <Content Include="libs\olm\ARM\olm.dll">
      <Link>olm.dll</Link>
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
